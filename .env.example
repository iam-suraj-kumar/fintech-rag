PORTKEY_API_KEY=

# Optional override (see core/llm.py)
LLM_MODEL=@demo-fintech/gpt-4o
# Optional override (see core/embeddings.py)
EMBEDDING_MODEL=@demo-fintech/text-embedding-3-small

# Qdrant runs in local (embedded, on-disk) mode by default -- no server needed.
# Optional override (see core/clients.py)
QDRANT_LOCAL_PATH=data/qdrant_local
# Optional; set to point at a running Qdrant server instead of local mode
QDRANT_URL=
