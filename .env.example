ANTHROPIC_API_KEY=
OPENAI_API_KEY=
VOYAGE_API_KEY=
QDRANT_URL=http://localhost:6333

# LLM provider for answer generation: anthropic | openai | local
LLM_PROVIDER=anthropic
# Optional override; defaults to a sensible model per provider (see core/llm.py)
LLM_MODEL=
# Only used when LLM_PROVIDER=local (any OpenAI-compatible server, e.g. Ollama)
LOCAL_LLM_BASE_URL=http://localhost:11434/v1

# Dense embedding provider: voyage | openai | local
EMBEDDING_PROVIDER=voyage
# Optional override; defaults to a sensible model per provider (see core/embeddings.py)
EMBEDDING_MODEL=
# Only used when EMBEDDING_PROVIDER=local (any OpenAI-compatible server, e.g. Ollama)
LOCAL_EMBEDDING_BASE_URL=http://localhost:11434/v1
